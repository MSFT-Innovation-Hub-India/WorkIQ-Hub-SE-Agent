AZURE_OPENAI_ENDPOINT=https://rob-agent-aoai.openai.azure.com/openai/v1
AZURE_OPENAI_CHAT_MODEL=gpt-5.2
AZURE_OPENAI_CHAT_MODEL_SMALL=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2025-03-01-preview
ACS_ENDPOINT=https://pcdotai-comms.india.communication.azure.com
ACS_SENDER_ADDRESS=DoNotReply@ocvp-msft-india.com

# — Azure AD tenant ID for az login (e.g. for multi-tenant accounts)
AZURE_TENANT_ID=your-tenant-id-here

# — Azure subscription to select after login
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# Optional — override auto-detected OS timezone (IANA format)
# AGENT_TIMEZONE=Asia/Kolkata

# Optional — full path to workiq CLI if not on PATH
# WORKIQ_PATH=C:\Users\you\AppData\Roaming\npm\workiq.CMD

# Optional — Azure Managed Redis for remote task delivery (Teams integration)
# If not set, agent runs in local-only mode.
# AZ_REDIS_CACHE_ENDPOINT=your-redis.region.redis.azure.net:10000
# REDIS_SESSION_TTL_SECONDS=86400
